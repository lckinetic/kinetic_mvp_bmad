<mxfile host="app.diagrams.net">
  <diagram name="Kinetic System Overview">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="title" value="Kinetic System Overview" style="text;html=1;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="400" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="ui" value="User / UI (app/ui)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="api" value="FastAPI (app/api)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="engine" value="Workflow Engine (app/engine)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="120" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="workflows" value="Workflow Templates (app/workflows)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="260" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="services" value="Services (app/services)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="260" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="adapters" value="Adapters (Banxa / Privy / Coinbase)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="260" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="db" value="Database (app/db)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="380" width="200" height="80" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
