{
  "info": {
    "name": "Kinetic MVP API (Local)",
    "_postman_id": "7b4521fa-5a18-4c97-a4e8-4a62b9411ac2",
    "description": "Postman collection for Kinetic MVP local backend: health, onramp, and Banxa webhook tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/health"
      },
      "response": []
    },
    {
      "name": "Onramp - Create Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('onramp_order_id', body.order_id);",
              "pm.environment.set('onramp_checkout_url', body.checkout_url || '');",
              "pm.test('order_id exists', function () {",
              "  pm.expect(body.order_id).to.be.ok;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fiat_amount\": 100,\n  \"fiat_currency\": \"GBP\",\n  \"crypto_currency\": \"USDC\",\n  \"wallet_address\": \"0xabc123\",\n  \"blockchain\": \"ethereum\",\n  \"user_email\": \"test@example.com\"\n}"
        },
        "url": "{{base_url}}/onramp/orders"
      },
      "response": []
    },
    {
      "name": "Onramp - Get Order (by order_id)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('order_id matches env', function () {",
              "  pm.expect(body.order_id).to.eql(pm.environment.get('onramp_order_id'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/onramp/orders/{{onramp_order_id}}"
      },
      "response": []
    },
    {
      "name": "Webhook - Banxa (Update status to completed)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('webhook_idempotency_key')) {",
              "  pm.environment.set('webhook_idempotency_key', 'demo-update-001');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('last_webhook_status', body.status || '');",
              "pm.environment.set('last_webhook_idempotency_key', body.idempotency_key || '');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-IDEMPOTENCY-KEY",
            "value": "{{webhook_idempotency_key}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"order_completed\",\n  \"order_id\": \"{{onramp_order_id}}\",\n  \"status\": \"completed\"\n}"
        },
        "url": "{{base_url}}/webhooks/banxa"
      },
      "response": []
    },
    {
      "name": "Webhook - Banxa (Duplicate resend)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Duplicate is ignored or received', function () {",
              "  pm.expect(body.status).to.be.oneOf(['duplicate_ignored','received']);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-IDEMPOTENCY-KEY",
            "value": "{{webhook_idempotency_key}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"order_completed\",\n  \"order_id\": \"{{onramp_order_id}}\",\n  \"status\": \"completed\"\n}"
        },
        "url": "{{base_url}}/webhooks/banxa"
      },
      "response": []
    },
    {
      "name": "Sanity - Get Order After Webhook",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Order status is completed', function () {",
              "  pm.expect((body.order_status || '').toLowerCase()).to.eql('completed');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/onramp/orders/{{onramp_order_id}}"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    }
  ]
}